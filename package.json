{
  "name": "@xiaoqi-ai/ai-link",
  "version": "0.1.0",
  "description": "AI Link routes Codex tasks to configured models, agents, and workflows.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "ai-link": "dist/cli.js",
    "ai-link-gsc": "dist/connectors/gscCheck.js",
    "ai-link-gsc-auth": "dist/connectors/gscAuthorize.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node tools/build-runtime.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --import tsx --test \"src/**/*.test.ts\" && npm run auth-hub:test",
    "verify:fresh": "node tools/verify-fresh-clone.js",
    "package:check": "npm run build && node tools/check-package-contents.js",
    "package:check:json": "npm run build && node tools/check-package-contents.js --json",
    "package:install-smoke": "npm run build && node tools/check-package-install.js",
    "package:install-smoke:json": "npm run build && node tools/check-package-install.js --json",
    "next:actions": "node tools/show-next-actions.js",
    "next:actions:json": "node tools/show-next-actions.js --json",
    "setup:handoff": "node tools/show-setup-handoff.js",
    "setup:handoff:json": "node tools/show-setup-handoff.js --json",
    "maintainer:pack": "node tools/show-maintainer-action-pack.js",
    "maintainer:pack:json": "node tools/show-maintainer-action-pack.js --json",
    "external:preflight": "node tools/show-external-setup-preflight.js",
    "external:preflight:json": "node tools/show-external-setup-preflight.js --json",
    "roadmap:next": "node tools/show-roadmap-next.js",
    "roadmap:next:json": "node tools/show-roadmap-next.js --json",
    "iteration:boundary": "node tools/show-iteration-boundary.js",
    "iteration:boundary:json": "node tools/show-iteration-boundary.js --json",
    "github:safety": "node tools/check-github-repo-safety.js",
    "github:safety:json": "node tools/check-github-repo-safety.js --json",
    "github:hardening": "node tools/new-github-hardening-worksheet.js",
    "github:hardening:json": "node tools/new-github-hardening-worksheet.js --json",
    "github:hardening:next": "node tools/show-github-hardening-next.js",
    "github:hardening:next:json": "node tools/show-github-hardening-next.js --json",
    "release:plan": "node tools/check-release-plan.js",
    "release:plan:json": "node tools/check-release-plan.js --json",
    "release:decisions": "node tools/check-release-decisions.js",
    "release:decisions:json": "node tools/check-release-decisions.js --json",
    "release:decisions:strict": "node tools/check-release-decisions.js --strict",
    "release:decisions:next": "node tools/show-release-decision-next.js",
    "release:decisions:next:json": "node tools/show-release-decision-next.js --json",
    "release:decisions:update": "node tools/update-release-decision.js",
    "release:manual-gates": "node tools/show-release-manual-gates.js",
    "release:manual-gates:json": "node tools/show-release-manual-gates.js --json",
    "release:evidence": "node tools/new-release-evidence.js",
    "release:evidence:json": "node tools/new-release-evidence.js --json",
    "release:readiness": "node tools/check-release-readiness.js",
    "release:readiness:json": "node tools/check-release-readiness.js --json",
    "onboard": "npm run ai-link -- onboard",
    "onboard:print": "npm run ai-link -- onboard --print",
    "onboard:json": "npm run ai-link -- onboard --json",
    "onboard:check": "npm run ai-link -- onboard --json --strict",
    "skills:check": "node tools/check-codex-skills.js",
    "bws:plan": "powershell -ExecutionPolicy Bypass -File tools/show-bws-setup-plan.ps1",
    "bws:next": "node tools/show-bws-next.js",
    "bws:next:json": "node tools/show-bws-next.js --json",
    "bws:onboard": "powershell -ExecutionPolicy Bypass -File tools/start-bws-onboarding.ps1 -Force",
    "bws:onboard:print": "powershell -ExecutionPolicy Bypass -File tools/start-bws-onboarding.ps1 -Print",
    "bws:profile": "powershell -ExecutionPolicy Bypass -File tools/new-bws-local-profile.ps1 -Force",
    "bws:profile:print": "powershell -ExecutionPolicy Bypass -File tools/new-bws-local-profile.ps1 -Print",
    "bws:profile:from-bws": "powershell -ExecutionPolicy Bypass -File tools/new-bws-local-profile.ps1 -ResolveFromBws -Force",
    "bws:activate": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-activation.ps1",
    "bws:activate:help": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-activation.ps1 -Help",
    "bws:activate:plan": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-activation.ps1 -Plan",
    "bws:check": "powershell -ExecutionPolicy Bypass -File tools/check-bws-mode.ps1",
    "bws:check:strict": "powershell -ExecutionPolicy Bypass -File tools/check-bws-mode.ps1 -Strict",
    "bws:session": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-session.ps1",
    "bws:session:help": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-session.ps1 -Help",
    "bws:run": "powershell -ExecutionPolicy Bypass -File tools/with-bitwarden-secrets.ps1",
    "bws:run:help": "powershell -ExecutionPolicy Bypass -File tools/with-bitwarden-secrets.ps1 -Help",
    "bws:doctor": "powershell -ExecutionPolicy Bypass -File tools/invoke-bws-session.ps1 -UseBwsRun -CommandLine \"npm run ai-link -- doctor\"",
    "bws:worksheet": "powershell -ExecutionPolicy Bypass -File tools/new-bws-setup-worksheet.ps1 -Force",
    "bws:worksheet:print": "powershell -ExecutionPolicy Bypass -File tools/new-bws-setup-worksheet.ps1 -Print",
    "bws:rotation": "powershell -ExecutionPolicy Bypass -File tools/new-bws-rotation-plan.ps1 -Force",
    "bws:rotation:print": "powershell -ExecutionPolicy Bypass -File tools/new-bws-rotation-plan.ps1 -Print",
    "bws:rotation:help": "powershell -ExecutionPolicy Bypass -File tools/new-bws-rotation-plan.ps1 -Help",
    "bws:github-vars": "powershell -ExecutionPolicy Bypass -File tools/export-bws-github-provider-vars.ps1 -Force",
    "bws:github-vars:help": "powershell -ExecutionPolicy Bypass -File tools/export-bws-github-provider-vars.ps1 -Help",
    "bws:github-vars:apply": "powershell -ExecutionPolicy Bypass -File tools/apply-bws-github-provider-vars.ps1 -Apply",
    "bws:github-vars:apply-plan": "powershell -ExecutionPolicy Bypass -File tools/apply-bws-github-provider-vars.ps1 -Plan",
    "bws:github-vars:apply-help": "powershell -ExecutionPolicy Bypass -File tools/apply-bws-github-provider-vars.ps1 -Help",
    "bws:acceptance": "powershell -ExecutionPolicy Bypass -File tools/new-bws-acceptance-report.ps1 -Force",
    "bws:acceptance:print": "powershell -ExecutionPolicy Bypass -File tools/new-bws-acceptance-report.ps1 -Print",
    "bws:acceptance:json": "powershell -ExecutionPolicy Bypass -File tools/new-bws-acceptance-report.ps1 -Json",
    "bws:acceptance:strict": "powershell -ExecutionPolicy Bypass -File tools/new-bws-acceptance-report.ps1 -Strict -Force",
    "bws:acceptance:strict:json": "powershell -ExecutionPolicy Bypass -File tools/new-bws-acceptance-report.ps1 -Strict -Json",
    "providers:dry": "npm run ai-link -- providers verify",
    "providers:dry:json": "npm run ai-link -- providers verify --json",
    "providers:live": "npm run ai-link -- providers verify --live",
    "providers:live:safe-report": "npm run ai-link -- providers verify --live --json --safe --output runtime/tmp/provider-live-report.json",
    "providers:live:safe-report:strict": "npm run ai-link -- providers verify --live --strict --json --safe --output runtime/tmp/provider-live-report.json",
    "providers:github:check": "powershell -ExecutionPolicy Bypass -File tools/check-github-provider-live.ps1",
    "providers:github:remote-check": "powershell -ExecutionPolicy Bypass -File tools/check-github-provider-live.ps1 -CheckRemote",
    "providers:github:dispatch-plan": "powershell -ExecutionPolicy Bypass -File tools/invoke-provider-live-workflow.ps1 -Plan",
    "providers:github:dispatch": "powershell -ExecutionPolicy Bypass -File tools/invoke-provider-live-workflow.ps1 -Dispatch -AcknowledgeCost",
    "providers:github:dispatch-strict": "powershell -ExecutionPolicy Bypass -File tools/invoke-provider-live-workflow.ps1 -Dispatch -AcknowledgeCost -Strict",
    "workflow:dry": "npm run ai-link -- workflow run auto_ops --dry-run --input \"fresh workflow check\"",
    "gsc:check": "npm run build && node dist/connectors/gscCheck.js",
    "gsc:authorize": "npm run build && node dist/connectors/gscAuthorize.js",
    "gsc:schedule:plan": "powershell -ExecutionPolicy Bypass -File tools/install-gsc-monitor-task.ps1",
    "start": "node src/server.js",
    "ai-link": "tsx src/cli.ts",
    "auth-hub:start": "node src/server.js",
    "auth-hub:local:start": "powershell -ExecutionPolicy Bypass -File tools/start-auth-hub-local.ps1",
    "auth-hub:local:stop": "powershell -ExecutionPolicy Bypass -File tools/stop-auth-hub-local.ps1",
    "auth-hub:executor": "node src/executor/localExecutor.js",
    "auth-hub:executor:once": "node src/executor/localExecutor.js --once",
    "auth-hub:executor:start": "powershell -ExecutionPolicy Bypass -File tools/start-auth-hub-executor.ps1",
    "auth-hub:executor:stop": "powershell -ExecutionPolicy Bypass -File tools/stop-auth-hub-executor.ps1",
    "auth-hub:smoke": "powershell -ExecutionPolicy Bypass -File tools/test-auth-hub-flow.ps1",
    "auth-hub:audit-smoke": "powershell -ExecutionPolicy Bypass -File tools/test-auth-hub-audit-handoff.ps1",
    "auth-hub:deploy:check": "powershell -ExecutionPolicy Bypass -File tools/check-auth-hub-deployment.ps1",
    "auth-hub:remote:next": "node tools/show-auth-hub-remote-next.js",
    "auth-hub:remote:next:json": "node tools/show-auth-hub-remote-next.js --json",
    "auth-hub:status": "node tools/show-auth-status-next-actions.js",
    "auth-hub:status:json": "node tools/show-auth-status-next-actions.js --json",
    "auth-hub:status:strict": "node tools/show-auth-status-next-actions.js --strict",
    "auth-hub:github-adapter:new": "node tools/new-github-auth-private-adapter.js",
    "auth-hub:github-adapter:print": "node tools/new-github-auth-private-adapter.js --print",
    "auth-hub:github-adapter:json": "node tools/new-github-auth-private-adapter.js --json",
    "auth-hub:wechat-adapter:new": "node tools/new-wechat-official-health-private-adapter.js",
    "auth-hub:wechat-adapter:print": "node tools/new-wechat-official-health-private-adapter.js --print",
    "auth-hub:wechat-adapter:json": "node tools/new-wechat-official-health-private-adapter.js --json",
    "auth-hub:xhs-adapter:new": "node tools/new-xiaohongshu-readonly-private-adapter.js",
    "auth-hub:xhs-adapter:print": "node tools/new-xiaohongshu-readonly-private-adapter.js --print",
    "auth-hub:xhs-adapter:json": "node tools/new-xiaohongshu-readonly-private-adapter.js --json",
    "auth-hub:private-bundle:new": "node tools/new-private-connector-bundle.js",
    "auth-hub:private-bundle:print": "node tools/new-private-connector-bundle.js --print",
    "auth-hub:private-bundle:json": "node tools/new-private-connector-bundle.js --json",
    "auth-hub:remote:smoke": "powershell -ExecutionPolicy Bypass -File tools/test-auth-hub-remote.ps1 -SkipAppLogin -ExpectAccessGate",
    "auth-hub:secrets:new": "powershell -ExecutionPolicy Bypass -File tools/new-auth-hub-secrets.ps1",
    "auth-hub:retention": "node tools/run-auth-hub-retention.js",
    "auth-hub:retention:json": "node tools/run-auth-hub-retention.js --json",
    "auth-hub:test:postgres": "node --test --test-concurrency=1 tests/postgres-store.integration.test.js",
    "auth-hub:test": "node --test tests/*.test.js",
    "security:scan": "node tools/security-scan.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.12.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
