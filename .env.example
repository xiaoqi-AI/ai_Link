# Copy to .env for local development only. Never commit real secrets.
NODE_ENV=development
PORT=10000
AI_LINK_BASE_URL=http://localhost:10000

# App console login.
AI_LINK_APP_PASSWORD=replace-with-local-password
AI_LINK_SESSION_SECRET=replace-with-long-random-session-secret
# Signed console sessions expire on the server after 8 hours by default.
AI_LINK_SESSION_MAX_AGE_SECONDS=28800

# Bearer tokens. Store real values only in Render secrets or local .env.
AI_LINK_ADMIN_TOKEN=replace-with-admin-token
AI_LINK_EXECUTOR_TOKEN=replace-with-executor-token
# Server-side identity bound to AI_LINK_EXECUTOR_TOKEN. The local executor must
# use the same id; production refuses to start without this binding.
AI_LINK_EXECUTOR_ID=local-executor
AI_LINK_CODEX_TOKEN=replace-with-codex-token

# Auth Hub controls heartbeat expiry. The executor reports every polling cycle;
# heartbeat failure never blocks task leasing.
AI_LINK_EXECUTOR_HEARTBEAT_TTL_MS=60000
# A successful explicit connector_probe remains valid for 15 minutes. Expiry
# is fail-closed and never triggers a platform call by itself.
AI_LINK_CONNECTOR_PROBE_TTL_MS=900000

# Cloudflare Access origin guard. When enabled, the application fails closed
# unless the signed Access JWT can be verified with the AUD tag and team domain.
AI_LINK_REQUIRE_CLOUDFLARE_ACCESS=false
AI_LINK_ALLOWED_ACCESS_EMAILS=owner@example.com
AI_LINK_CLOUDFLARE_ACCESS_ALLOW_SERVICE_TOKEN=true
AI_LINK_CLOUDFLARE_ACCESS_AUD=replace-with-cloudflare-access-aud
AI_LINK_CLOUDFLARE_TEAM_DOMAIN=your-team.cloudflareaccess.com
# AI_LINK_CLOUDFLARE_ACCESS_ISSUER=https://your-team.cloudflareaccess.com

# Optional local executor headers for Cloudflare Access Service Auth.
# CF_ACCESS_CLIENT_ID=replace-with-access-client-id
# CF_ACCESS_CLIENT_SECRET=replace-with-access-client-secret

# Optional repository-local private connector entry. Generate and review every
# adapter under runtime/private before generating the combined entry module.
# AI_LINK_PRIVATE_CONNECTOR_MODULE=runtime/private/platform-connectors.mjs
# AI_LINK_XHS_READONLY_BRIDGE=runtime/private/xiaohongshu-readonly-bridge.mjs
# AI_LINK_XHS_READONLY_TIMEOUT_MS=120000

# Optional direct-origin smoke test headers when validating the app guard.
# AI_LINK_CF_ACCESS_TEST_EMAIL=owner@example.com
# AI_LINK_CF_ACCESS_TEST_JWT=replace-with-access-jwt

# Required in production. Local development may omit it and use the in-memory store.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional approval email notifications. Email bodies intentionally contain no
# raw content, screenshots, cookies, tokens, or platform account details.
# SMTP_URL=smtp://user:password@smtp.example.com:587
# APPROVAL_EMAIL_TO=owner@example.com
# APPROVAL_EMAIL_FROM=AI Link <no-reply@example.com>
