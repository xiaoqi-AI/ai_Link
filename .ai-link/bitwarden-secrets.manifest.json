{
  "version": 1,
  "mode": "bws-managed-secrets",
  "organization": "ai-link-lab",
  "projects": {
    "localDev": {
      "name": "ai-link-local-dev",
      "machineAccount": "ma-ai-link-local-codex",
      "expectedSecretKeys": [
        "OPENAI_COMPATIBLE_API_KEY",
        "DEEPSEEK_API_KEY",
        "MOONSHOT_API_KEY",
        "XAI_API_KEY",
        "AI_LINK_APP_PASSWORD",
        "AI_LINK_SESSION_SECRET",
        "AI_LINK_ADMIN_TOKEN",
        "AI_LINK_EXECUTOR_TOKEN",
        "AI_LINK_CODEX_TOKEN",
        "DATABASE_URL",
        "SMTP_URL"
      ]
    },
    "ci": {
      "name": "ai-link-ci",
      "machineAccount": "ma-ai-link-github-actions",
      "githubEnvironmentSecret": "BW_ACCESS_TOKEN",
      "expectedSecretKeys": [
        "DEEPSEEK_API_KEY",
        "MOONSHOT_API_KEY",
        "XAI_API_KEY"
      ]
    }
  },
  "githubEnvironments": {
    "providerLive": {
      "name": "provider-live",
      "machineAccount": "ma-ai-link-github-actions",
      "bootstrapSecret": "BW_ACCESS_TOKEN",
      "secretIdVariables": {
        "OPENAI_COMPATIBLE_API_KEY": "BWS_OPENAI_COMPATIBLE_API_KEY_SECRET_ID",
        "DEEPSEEK_API_KEY": "BWS_DEEPSEEK_API_KEY_SECRET_ID",
        "MOONSHOT_API_KEY": "BWS_MOONSHOT_API_KEY_SECRET_ID",
        "XAI_API_KEY": "BWS_XAI_API_KEY_SECRET_ID"
      }
    }
  },
  "rules": [
    "Secret keys are environment variable names only.",
    "Secret values must never be written to Git, docs, issue text, pull requests, screenshots, or knowledge-base mirrors.",
    "BWS_ACCESS_TOKEN and BW_ACCESS_TOKEN are bootstrap tokens and must only live in local session environment variables or GitHub Environment Secrets."
  ]
}
